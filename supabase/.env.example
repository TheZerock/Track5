# ============================================================
# Variables de entorno para las Edge Functions de Supabase.
# Configúralas como secrets (nunca en el frontend):
#   supabase secrets set ALPHA_VANTAGE_API_KEY=tu_key
# o desde el Dashboard: Edge Functions -> Secrets
# ============================================================

# Ya provistas automáticamente por el entorno de Edge Functions:
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Requeridas por fetch-market-prices (acciones, ETFs y divisas):
# Gratis en https://www.alphavantage.co/support/#api-key — límite: 25 requests/día
ALPHA_VANTAGE_API_KEY=

# CoinGecko (criptoactivos) — no requiere API key en el plan público, no hace falta configurar nada aquí.

# Opcional — solo si quieres precio spot real de metales en vez del proxy vía GLD.
# Gratis en https://metals-api.com
METALS_API_KEY=

# Ya usadas por ingest-news (noticias):
# NEWSAPI_KEY=
# GEMINI_API_KEY=
